# Application Settings
APP_NAME=OneCloud Support Chatbot API
VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=7860

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://localhost:3000,https://localhost:3001,*

# Database Settings
DATABASE_URL=sqlite:///./onecloud_chatbot.db

# Dataset Paths
DATASET_PATH=../dataset
ENGLISH_DATASET=dataset-for-chat-eng.json
MYANMAR_DATASET=dataset-for-chat-mm.json

# Chat Settings
MAX_MESSAGE_LENGTH=1000
TYPING_DELAY=1.5
MAX_CONVERSATION_HISTORY=50

# Handoff Settings
HANDOFF_EMAIL=support@onecloud.com
HANDOFF_PHONE=+95-9-123456789

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
